# api gateway
VITE_RELATIVE_API_PATH=api/index.php
VITE_DEV_PROXY_TARGET=false

# name of the module folder in server
VITE_WEB_MODULES_FOLDER=modules

# for build
VITE_COMPRESSION_ENABLE=true
VITE_ANALYZER_ENABLE=false
VITE_SOURCEMAP=false
VITE_MANUAL_CHUNKS_ENABLE=false

# for release
VITE_BUILD_ID=PLACEHOLDER_BUILD
