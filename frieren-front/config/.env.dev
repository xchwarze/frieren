# api gateway
VITE_RELATIVE_API_PATH=api/index.php
VITE_DEV_PROXY_TARGET=http://192.168.7.1:5000

# name of the module folder in server
VITE_WEB_MODULES_FOLDER=modules

# enable terminal in panel
VITE_ENABLE_TERMINAL=true

# for build
VITE_COMPRESSION_ENABLE=true
VITE_ANALYZER_ENABLE=false
VITE_SOURCEMAP=false
VITE_MANUAL_CHUNKS_ENABLE=true

# for release
VITE_APP_VERSION=1.4.0
VITE_BUILD_ID=dev
