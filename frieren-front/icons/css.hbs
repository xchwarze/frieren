@font-face {
  font-display: block;
  font-family: "{{ name }}";
  src: {{{ fontSrc }}};
}

i[class^="{{ prefix }}-"], i[class*=" {{ prefix }}-"] {
  /* use !important to prevent issues with browser extensions that change fonts */
  font-family: "{{ name }}" !important;
  speak: never;
  font-style: normal;
  font-weight: normal;
  font-variant: normal;
  text-transform: none;
  line-height: 1;

  /* Better Font Rendering =========== */
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

{{# each codepoints }}
.{{ ../prefix }}-{{ @key }}:before {
  content: "\\{{ codepoint this }}";
}
{{/ each }}
