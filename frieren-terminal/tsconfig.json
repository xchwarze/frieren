{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "ttyd/html/src/components/terminal/xterm/addons/overlay": ["./src/typings/ttyd.d.ts"],
      "ttyd/html/src/components/terminal/xterm/addons/zmodem": ["./src/typings/ttyd.d.ts"],
      "ttyd/html/src/components/terminal/xterm": ["./src/typings/ttyd.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
